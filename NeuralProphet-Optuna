# 9. Forecast the Entire Year of 2024
# -------------------------------

# Create Hourly Dataframe of 2024
future_2024 = pd.DataFrame({
    'ds': pd.date_range(start='2024-01-01', end='2024-12-31 23:00:00', freq='H')
})


# Add the Regressor
future_2024 = calculate_all_features(future_2024)
print(future_2024.head(24))


# Daily Forecasting Loop with Error Fixing
import gc

all_predictions = []
# Store n_lags for Memory Optimization
current_data = df.iloc[-best_params['n_lags']:].copy()

start_date = pd.Timestamp('2024-01-01')
end_date = pd.Timestamp('2024-12-31')
date_range = pd.date_range(start=start_date, end=end_date, freq='D')

for day_idx, day in enumerate(date_range):
    if day_idx % 10 == 0:
        print(f"⏳ {day.strftime('%Y-%m-%d')} işleniyor... ({day_idx + 1}/{len(date_range)})")

    # Filter the Relevant Date
    day_mask = (future_2024['ds'] >= day) & (future_2024['ds'] < day + pd.Timedelta(days=1))
    day_df = future_2024[day_mask].copy()

    # Storage for Daily Predcitions
    day_predictions = []

    for i in range(len(day_df)):
        # Create New Row
        new_row = day_df.iloc[i].copy()
        new_row_df = pd.DataFrame([new_row])

        # Add to the Current Data
        current_data = pd.concat([current_data, new_row_df], ignore_index=True)

        # Forecast
        try:
            fcst = final_model.predict(current_data)
        except Exception as e:
            print(f"Hata: {e}, tarih: {new_row['ds']}")
            fcst = pd.DataFrame({'yhat1': [0]})

        # Predicted Column
        pred_col = 'yhat1' if 'yhat1' in fcst.columns else 'yhat'
        pred = fcst.iloc[-1][pred_col] if len(fcst) > 0 else 0
        # Save the Prediction
        day_predictions.append({
            'ds': new_row['ds'],
            'y': pred
        })

        # Add the Prediction to the Current Data
        current_data.loc[len(current_data) - 1, 'y'] = pred

        # Set the Window Size to n_lags
        current_data = current_data.iloc[-best_params['n_lags']:]

    # Convert the Prediction to Dataframe
    day_predictions_df = pd.DataFrame(day_predictions)
    all_predictions.append(day_predictions_df)

    # Clear the Memory
    if day_idx % 5 == 0:
        gc.collect()

final_2024 = pd.concat(all_predictions, ignore_index=True)
final_2024.head(24)
final_2024.to_csv("2024_daily_forecasted_motor_consumptions.csv", index=False)

